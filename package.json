{
  "name": "reactx",
  "version": "1.0.0-alpha.4",
  "description": "Transparent reactive state management",
  "keywords": [
    "state",
    "management",
    "react",
    "mobx"
  ],
  "author": "Christian Alfoni",
  "directories": {
    "doc": "docs"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/esm/index.js",
  "main": "./dist/esm/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.cjs"
    },
    "./devtools": {
      "import": "./dist/esm/devtools/index.js",
      "types": "./dist/esm/devtools/index.d.ts"
    },
    "./vite-plugin": {
      "import": "./dist/esm/vite-plugin.js",
      "types": "./dist/esm/vite-plugin.d.ts",
      "require": "./dist/cjs/vite-plugin.cjs"
    }
  },
  "types": "./dist/esm/index.d.ts",
  "scripts": {
    "build": "yarn clean && yarn build:cjs && yarn build:esm",
    "build:cjs": "tsc -p ./tsconfig.build-cjs.json && node renameToCjs.js",
    "build:esm": "tsc -p ./tsconfig.build-esm.json",
    "clean": "rimraf ./dist",
    "test": "vitest",
    "prepare": "yarn build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.2.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitepress": "^1.6.3",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "babel-plugin-observing-components": "^0.2.0",
    "mobx": "^6.13.7",
    "mobx-react-lite": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "license": "ISC"
}
